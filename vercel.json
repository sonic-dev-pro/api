{
  "version": 2,
  "builds": [
    {
      "src": "api/instagram.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/youtube.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ai-image.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/write.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/img2prompt.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/instagram",
      "dest": "/api/instagram.js"
    },
    {
      "src": "/api/youtube",
      "dest": "/api/youtube.js"
    },
    {
      "src": "/api/ai-image",
      "dest": "/api/ai-image.js"
    },
    {
      "src": "/api/write",
      "dest": "/api/write.js"
    },
    {
      "src": "/api/img2prompt",
      "dest": "/api/img2prompt.js"
    },
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js"
    }
  ]
}
