{
  "version": 2,
  "builds": [
    {
      "src": "api/instagram.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/youtube.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ai-image.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/write.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/img2prompt.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/wallpaper.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/stalkchannel.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ig-stalk.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/record-web.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/biden.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/twitter.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/instagram",
      "dest": "/api/instagram.js"
    },
    {
      "src": "/api/youtube",
      "dest": "/api/youtube.js"
    },
    {
      "src": "/api/ai-image",
      "dest": "/api/ai-image.js"
    },
    {
      "src": "/api/write",
      "dest": "/api/write.js"
    },
    {
      "src": "/api/img2prompt",
      "dest": "/api/img2prompt.js"
    },
    {
      "src": "/api/wallpaper",
      "dest": "/api/wallpaper.js"
    },
    {
      "src": "/api/stalkchannel",
      "dest": "/api/stalkchannel.js"
    },
    {
      "src": "/api/ig-stalk",
      "dest": "/api/ig-stalk.js"
    },
    {
      "src": "/api/record-web",
      "dest": "/api/record-web.js"
    },
    {
      "src": "/api/biden",
      "dest": "/api/biden.js"
    },
    {
      "src": "/api/twitter",
      "dest": "/api/twitter.js"
    },
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
